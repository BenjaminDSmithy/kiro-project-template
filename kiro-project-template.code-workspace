{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "kiroAgent.configureMCP": "Enabled",
    "editor.formatOnSave": true,
    "editor.trimAutoWhitespace": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "[typescript]": { "editor.tabSize": 2 },
    "[typescriptreact]": { "editor.tabSize": 2 },
    "[javascript]": { "editor.tabSize": 2 },
    "[html]": { "editor.tabSize": 2 },
    "[css]": { "editor.tabSize": 2 },
    "[json]": { "editor.tabSize": 2 },
    "[jsonc]": { "editor.tabSize": 2 },
    "search.exclude": {
      "**/node_modules": true,
      "**/.next": true,
      "**/dist": true,
      "**/.trunk": true,
      "**/.hypothesis": true,
      "**/playwright-report": true,
      "**/test-results": true
    },
    "files.watcherExclude": {
      "**/.git/**": true,
      "**/node_modules/**": true,
      "**/.next/**": true,
      "**/dist/**": true,
      "**/.trunk/**": true,
      "**/.hypothesis/**": true,
      "**/playwright-report/**": true,
      "**/test-results/**": true
    }
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node-terminal",
        "request": "launch",
        "name": "── Setup ──────────────────────",
        "command": "echo"
      },
      {
        "name": "🚀 Run Setup Script",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/setup.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "type": "node-terminal",
        "request": "launch",
        "name": "── CLI ────────────────────────",
        "command": "echo"
      },
      {
        "name": "🔨 CLI: Build",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/build.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "name": "🧪 CLI: Test",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/test.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "name": "▶️ CLI: Init (interactive)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/run-init.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "name": "▶️ CLI: Add (interactive)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/run-add.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "type": "node-terminal",
        "request": "launch",
        "name": "── Publishing ─────────────────",
        "command": "echo"
      },
      {
        "name": "📋 CLI: Changelog",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/changelog.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "name": "✅ CLI: Pre-publish Checks",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/prepublish.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "name": "🚢 CLI: Release (Gitflow)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/release.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      },
      {
        "type": "node-terminal",
        "request": "launch",
        "name": "── Templates ──────────────────",
        "command": "echo"
      },
      {
        "name": "📦 CLI: Copy Templates",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "/bin/bash",
        "runtimeArgs": ["${workspaceFolder}/cli/scripts/copy-templates.sh"],
        "console": "integratedTerminal",
        "env": { "NODE_OPTIONS": "" }
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "🚀 Run Setup Script",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/setup.sh"],
        "options": { "cwd": "${workspaceFolder}" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "focus": true, "group": "setup" }
      },
      {
        "label": "🔨 CLI: Build",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/build.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "group": "build",
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "group": "cli" }
      },
      {
        "label": "🧪 CLI: Test",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/test.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "group": "test",
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "group": "cli" }
      },
      {
        "label": "▶️ CLI: Init (interactive)",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/run-init.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "focus": true, "group": "cli" }
      },
      {
        "label": "▶️ CLI: Add (interactive)",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/run-add.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "focus": true, "group": "cli" }
      },
      {
        "label": "📋 CLI: Changelog",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/changelog.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "group": "publish" }
      },
      {
        "label": "✅ CLI: Pre-publish Checks",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/prepublish.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "group": "publish" }
      },
      {
        "label": "🚢 CLI: Release (Gitflow)",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/release.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "focus": true, "group": "publish" }
      },
      {
        "label": "📦 CLI: Copy Templates",
        "type": "shell",
        "command": "bash",
        "args": ["-lc", "bash ${workspaceFolder}/cli/scripts/copy-templates.sh"],
        "options": { "cwd": "${workspaceFolder}/cli" },
        "problemMatcher": [],
        "presentation": { "reveal": "always", "panel": "dedicated", "group": "cli" }
      }
    ]
  },
  "extensions": {
    "recommendations": [
      "trunk.io",
      "bradlc.vscode-tailwindcss",
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "mikestead.dotenv",
      "eamodio.gitlens"
    ]
  },
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "disabled": false
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "."],
      "disabled": false
    },
    "chrome": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "disabled": false
    },
    "docker": {
      "command": "uvx",
      "args": ["mcp-server-docker"],
      "disabled": true
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"],
      "disabled": false
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "disabled": false
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "disabled": false
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--read-only"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      },
      "disabled": true
    }
  }
}
